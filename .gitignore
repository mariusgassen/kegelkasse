# IntelliJ / JetBrains .idea folder

# User-specific stuff
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/**/dictionaries
.idea/**/shelf

# Generated files
.idea/**/contentModel.xml


# Gradle / build tool integrations
.idea/**/gradle.xml
.idea/**/libraries

# Misc
.idea/**/uiDesigner.xml

# OS files

.DS_Store
Thumbs.db

# Environment
backend/.env
backend/.env.example
!backend/.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/

# Poetry
# poetry.lock is intentionally tracked so Docker builds work in CI/CD

# Alembic
backend/alembic/versions/__pycache__/

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/dev-dist/

# IDE
.idea/workspace.xml
.idea/shelf/
*.iml

# OS
.DS_Store
Thumbs.db

# Docker
postgres_data/
postgres_dev_data/

# Logs
*.logdocs/build
docs/node_modules
/backend/docs_static/
