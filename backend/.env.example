DATABASE_URL=postgresql://kegelkasse:changeme@db:5432/kegelkasse
POSTGRES_PASSWORD=changeme
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ENVIRONMENT=production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
FIRST_SUPERADMIN_EMAIL=admin@kegelkasse.de
FIRST_SUPERADMIN_PASSWORD=change_after_first_login

# Web Push (VAPID) — optional; push notifications are disabled when left empty.
# Generate keys once with:
#   docker compose run --rm app python app/scripts/generate_vapid.py
# Then paste the printed VAPID_PRIVATE_KEY and VAPID_PUBLIC_KEY values below.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=admin@kegelkasse.de

# Database backups
# Cron schedule for automatic backups (default: daily at 02:00)
BACKUP_SCHEDULE=0 2 * * *
# How many days of local backups to keep on disk (default: 7)
BACKUP_RETAIN_DAYS=7

# S3 backup upload — leave S3_BUCKET empty to disable S3 uploads.
# Works with any S3-compatible storage (AWS S3, Hetzner Object Storage, MinIO, etc.)
S3_BUCKET=
S3_PREFIX=kegelkasse/backups
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
