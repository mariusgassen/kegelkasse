DATABASE_URL=postgresql://kegelkasse:changeme@db:5432/kegelkasse
POSTGRES_PASSWORD=changeme
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ENVIRONMENT=production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
FIRST_SUPERADMIN_EMAIL=admin@kegelkasse.de
FIRST_SUPERADMIN_PASSWORD=change_after_first_login

# Web Push (VAPID) — optional; push notifications are disabled when left empty.
# Generate keys once with:
#   docker compose run --rm app python app/scripts/generate_vapid.py
# Then paste the printed VAPID_PRIVATE_KEY and VAPID_PUBLIC_KEY values below.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=admin@kegelkasse.de

# pgbackrest — automatic scheduled backup (default: full backup daily at 02:00 UTC)
BACKUP_SCHEDULE=0 2 * * *

# Number of full backup sets to retain (each full set includes its WAL for PITR)
BACKUP_RETAIN_FULL=2

# pgbackrest management API URL (internal Docker network — do not expose externally)
# NOTE: must NOT use the PGBACKREST_ prefix — pgbackrest would treat it as a config option
PGB_MGMT_URL=http://db:8089

# S3-compatible repository (optional — leave empty to use the local pgbackrest_repo volume)
# pgbackrest supports AWS S3, Hetzner Object Storage, MinIO, etc.
# To enable: set PGBACKREST_REPO1_TYPE=s3 on the db service and configure the vars below.
# See: https://pgbackrest.org/configuration.html#section-repository/option-repo-type
#PGBACKREST_REPO1_TYPE=s3
#PGBACKREST_REPO1_S3_BUCKET=my-bucket
#PGBACKREST_REPO1_S3_ENDPOINT=fsn1.your-objectstorage.com  # Hetzner example
#PGBACKREST_REPO1_S3_KEY=
#PGBACKREST_REPO1_S3_KEY_SECRET=
#PGBACKREST_REPO1_S3_REGION=us-east-1
